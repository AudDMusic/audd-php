{
    "name": "audd/audd",
    "description": "Official PHP SDK for the AudD music recognition API.",
    "type": "library",
    "license": "MIT",
    "homepage": "https://audd.io",
    "keywords": ["audd", "music", "recognition", "audio", "fingerprinting", "shazam"],
    "support": {
        "issues": "https://github.com/AudDMusic/audd-php/issues",
        "source": "https://github.com/AudDMusic/audd-php",
        "email": "api@audd.io",
        "docs": "https://docs.audd.io"
    },
    "authors": [
        {
            "name": "AudD",
            "email": "api@audd.io",
            "homepage": "https://audd.io"
        }
    ],
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "guzzlehttp/guzzle": "^7.5",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/http-factory": "^1.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "friendsofphp/php-cs-fixer": "^3.50"
    },
    "autoload": {
        "psr-4": {
            "AudD\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AudD\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always --testsuite=unit",
        "test-unit": "phpunit --colors=always --testsuite=unit",
        "test-contract": "phpunit --colors=always --testsuite=contract",
        "test-all": "phpunit --colors=always",
        "stan": "phpstan analyse --memory-limit=512M",
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.4.x-dev"
        }
    },
    "minimum-stability": "stable"
}
