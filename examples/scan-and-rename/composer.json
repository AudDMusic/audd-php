{
    "name": "audd/example-scan-and-rename",
    "description": "Walk a folder, recognize each audio file with AudD, write tags, rename to 'Artist - Title.ext'.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-json": "*",
        "audd/audd": "^1.4.5",
        "james-heinrich/getid3": "^2.0"
    },
    "minimum-stability": "beta",
    "prefer-stable": true,
    "repositories": [
        {
            "type": "path",
            "url": "../..",
            "options": {
                "symlink": false,
                "versions": {
                    "audd/audd": "1.4.5"
                }
            }
        }
    ],
    "config": {
        "sort-packages": true
    }
}
